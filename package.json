{
  "name": "zayka-pos-backend",
  "version": "1.0.0",
  "description": "ZaykaPOS Backend - Modular Architecture with shared modules",
  "private": true,
  "scripts": {
    "start:api": "cd services/backend && node server.js",
    "start:admin": "cd services/admin && node server.js",
    "start": "concurrently \"npm run start:api\" \"npm run start:admin\"",
    "dev:api": "cd services/backend && npx nodemon server.js",
    "dev:admin": "cd services/admin && npx nodemon server.js",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:admin\"",
    "seed": "node scripts/seed.js",
    "migrate": "node scripts/migrate.js",
    "migrate:force": "node scripts/migrate.js --force",
    "migrate:alter": "node scripts/migrate.js --alter",
    "cleanup": "node scripts/cleanup.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.3.1",
    "mysql2": "^3.6.5",
    "sequelize": "^6.35.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
